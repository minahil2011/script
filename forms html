<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Instagram · Sign Up</title>
  <link rel="stylesheet" href="forms.css"/>
</head>
<body>

<div class="col">

  <div class="signup-card">
    <div class="logo-ring">
      <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
    </div>
    <h1 class="app-name">Instagram</h1>
    <p class="tagline">Sign up to see photos and videos<br>from your friends.</p>

    <form name="signupForm" onsubmit="return validateForm()">
      <div class="field">
        <input type="text" name="fullname" placeholder="Full Name"/>
        <p class="msg" id="msg-name"></p>
      </div>
      <div class="field">
        <input type="text" name="email" placeholder="Email address"/>
        <p class="msg" id="msg-email"></p>
      </div>
      <div class="field">
        <input type="password" name="password" placeholder="Password"/>
        <p class="msg" id="msg-pwd"></p>
      </div>
      <div class="field">
        <input type="number" name="age" placeholder="Age" min="1"/>
        <p class="msg" id="msg-age"></p>
      </div>
      <button type="submit" class="btn-submit">Sign up</button>
    </form>

    <div class="or">OR</div>

    <button class="btn-google">
      <svg width="16" height="16" viewBox="0 0 24 24">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Continue with Google
    </button>

    <p class="terms">
      By signing up, you agree to our <a href="#">Terms</a>, <a href="#">Privacy Policy</a> and <a href="#">Cookies Policy</a>.
    </p>

    <div id="success"></div>
  </div>

  <div class="login-card">
    Have an account? <a href="#">Log in</a>
  </div>

  <div class="getapp-card">
    <p>Get the app.</p>
    <div class="badge-row">
      <a href="#" class="badge">
        <span class="badge-icon">🍎</span>
        <span class="badge-text">
          <span class="sub">Download on the</span>
          <span class="name">App Store</span>
        </span>
      </a>
      <a href="#" class="badge">
        <span class="badge-icon">▶</span>
        <span class="badge-text">
          <span class="sub">Get it on</span>
          <span class="name">Google Play</span>
        </span>
      </a>
    </div>
  </div>

</div>

<footer>
  <a href="#">About</a><a href="#">Help</a><a href="#">Press</a><a href="#">API</a><a href="#">Jobs</a>
  <a href="#">Privacy</a><a href="#">Terms</a><a href="#">Locations</a><a href="#">Language</a>
  <br>© 2024 INSTAGRAM FROM META
</footer>

<script src="forms.js"></script>

</body>
</html>
